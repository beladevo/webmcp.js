{
  "name": "@webmcp-js/react",
  "version": "0.1.0",
  "description": "React bindings for webmcp.js.",
  "type": "module",
  "license": "MIT",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.tsx --format esm --dts --sourcemap --clean --external react",
    "test": "vitest run --environment jsdom",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@webmcp-js/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.2.0"
  },
  "devDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  }
}
